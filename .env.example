# ===== Database (MySQL) =====
DB_HOST=db
DB_PORT=3306
DB_USER=debtuser
DB_PASSWORD=debtpass
DB_NAME=debt_eliminator
DB_ROOT_PASSWORD=rootpass

# ===== Application =====
APP_PORT=7070
NODE_ENV=development

# ===== Auth =====
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ===== Super Admin (bootstrapped on first server startup) =====
SUPER_ADMIN_EMAIL=dgeofrey@admin.local
SUPER_ADMIN_PASSWORD=YourSuperAdminPassword!
SUPER_ADMIN_NAME=David Geofrey

# ===== Geo AI Assistant =====
# Disabled by default - no downloads, no API key needed.
# The app works fully without Geo (just no chat button).
# To enable later, set GEO_ENABLED=true and configure Ollama or another backend.
GEO_ENABLED=false
